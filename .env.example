# Telegram Bot Configuration
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Channel Subscription Gate (Optional)
# The channel ID that users must subscribe to before playing
# Format: @channel_username or -1001234567890 (for private channels)
REQUIRED_CHANNEL_ID=@your_channel_username

# Game Configuration
# Secret key for signing JWT tokens (generate a random string)
JWT_SECRET=your_random_secret_key_here

# Environment
NODE_ENV=production